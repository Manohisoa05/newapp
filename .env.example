# Optionnel: pré-remplir la config Webservice en dev (sans passer par l'écran Configuration)
# ⚠️ La clé reste visible côté navigateur (pas de backend custom)

# Base URL de ta boutique PrestaShop
VITE_PS_SHOP_BASE_URL=http://localhost/eval

# Clé Webservice PrestaShop (Paramètres avancés -> Webservice)
VITE_PS_WS_KEY=CHANGE_ME
